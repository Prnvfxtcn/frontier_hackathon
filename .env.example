# Chain
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_NETWORK_LABEL="Base Sepolia"
DEPLOYER_PRIVATE_KEY=0x...

# Contracts (filled after deploy)
NEXT_PUBLIC_CONSENT_REGISTRY=0x...
NEXT_PUBLIC_INFERENCE_REGISTRY=0x...
NEXT_PUBLIC_SETTLEMENT=0x...
NEXT_PUBLIC_MOCK_USDC=0x...

# Demo receipt for judges (filled by scripts/seed-public-demo.sh)
NEXT_PUBLIC_DEMO_RECEIPT_ID=0x...

# Optional Basescan verification during deploy-base-sepolia.sh
BASESCAN_API_KEY=

# AI service
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_URL=http://localhost:8000
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
USE_MOCK_EXTRACTOR=false
COHERENCE_THRESHOLD=80
GROUNDING_TAU=0.6
# AGREEMENT_THRESHOLD: minimum overall ensemble agreement (0-100) required before a receipt can be minted. Default 80; raised to 90 for the demo to surface natural model variance on hard cases.
AGREEMENT_THRESHOLD=90

# WalletConnect (RainbowKit) — free project id
NEXT_PUBLIC_WALLETCONNECT_ID=
